<!DOCTYPE html>

<html class="light" lang="pt-br">

<head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <title>EduManage - Login</title>
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Hanken+Grotesk:wght@400;600;700&amp;display=swap"
                rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
                rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
                rel="stylesheet" />
        <script id="tailwind-config">
                tailwind.config = {
                        darkMode: "class",
                        theme: {
                                extend: {
                                        "colors": {
                                                "tertiary-container": "#212425",
                                                "surface-container": "#e6eff8",
                                                "on-error": "#ffffff",
                                                "error-container": "#ffdad6",
                                                "on-secondary-container": "#00743a",
                                                "secondary-fixed": "#6bfe9c",
                                                "on-background": "#141d23",
                                                "secondary-container": "#6bfe9c",
                                                "on-primary-fixed": "#001b3d",
                                                "primary-fixed": "#d6e3ff",
                                                "primary": "#000e24",
                                                "on-primary-container": "#718bb9",
                                                "on-surface-variant": "#43474e",
                                                "secondary-fixed-dim": "#4ae183",
                                                "primary-fixed-dim": "#adc7f8",
                                                "on-tertiary-fixed": "#191c1d",
                                                "on-secondary-fixed": "#00210c",
                                                "on-tertiary-container": "#898b8c",
                                                "on-tertiary": "#ffffff",
                                                "secondary": "#006d37",
                                                "on-secondary": "#ffffff",
                                                "background": "#f6faff",
                                                "surface-dim": "#d2dbe4",
                                                "inverse-surface": "#293138",
                                                "on-primary-fixed-variant": "#2c4771",
                                                "surface-container-highest": "#dbe4ed",
                                                "on-secondary-fixed-variant": "#005228",
                                                "surface-tint": "#455f8a",
                                                "surface-container-low": "#ecf5fe",
                                                "inverse-primary": "#adc7f8",
                                                "surface-container-high": "#e0e9f2",
                                                "surface": "#f6faff",
                                                "on-primary": "#ffffff",
                                                "tertiary-fixed-dim": "#c5c7c8",
                                                "tertiary": "#0c0e0f",
                                                "surface-bright": "#f6faff",
                                                "primary-container": "#00234b",
                                                "on-tertiary-fixed-variant": "#454748",
                                                "on-error-container": "#93000a",
                                                "inverse-on-surface": "#e9f2fb",
                                                "surface-container-lowest": "#ffffff",
                                                "outline": "#74777f",
                                                "surface-variant": "#dbe4ed",
                                                "outline-variant": "#c4c6d0",
                                                "on-surface": "#141d23",
                                                "error": "#ba1a1a",
                                                "tertiary-fixed": "#e1e3e4"
                                        },
                                        "borderRadius": {
                                                "DEFAULT": "0.125rem",
                                                "lg": "0.25rem",
                                                "xl": "0.5rem",
                                                "full": "0.75rem"
                                        },
                                        "spacing": {
                                                "unit": "4px",
                                                "md": "16px",
                                                "xl": "32px",
                                                "lg": "24px",
                                                "gutter": "16px",
                                                "xs": "4px",
                                                "sidebar_width": "260px",
                                                "header_height": "64px",
                                                "sm": "8px"
                                        },
                                        "fontFamily": {
                                                "title-sm": ["Inter"],
                                                "label-bold": ["Inter"],
                                                "label-sm": ["Inter"],
                                                "body-sm": ["Inter"],
                                                "body-md": ["Inter"],
                                                "headline-md": ["Hanken Grotesk"],
                                                "display-lg": ["Hanken Grotesk"]
                                        },
                                        "fontSize": {
                                                "title-sm": ["18px", { "lineHeight": "24px", "fontWeight": "600" }],
                                                "label-bold": ["12px", { "lineHeight": "16px", "fontWeight": "600" }],
                                                "label-sm": ["11px", { "lineHeight": "14px", "fontWeight": "500" }],
                                                "body-sm": ["13px", { "lineHeight": "18px", "fontWeight": "400" }],
                                                "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                                                "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                                                "display-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "700" }]
                                        }
                                },
                        },
                }
        </script>
        <style>
                .material-symbols-outlined {
                        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
                }

                body {
                        background-color: #f6faff;
                }
        </style>
</head>

<body class="min-h-screen flex flex-col font-body-md text-on-surface">
        <!-- Login Container -->
        <main class="flex-grow flex items-center justify-center p-md">
                <div
                        class="w-full max-w-[440px] bg-surface-container-lowest border border-outline-variant shadow-sm rounded-lg overflow-hidden">
                        <!-- Brand Identity Section -->
                        <div class="pt-xl px-xl pb-lg flex flex-col items-center text-center">
                                <div
                                        class="w-16 h-16 bg-primary-container flex items-center justify-center rounded-lg mb-md">
                                        <span class="material-symbols-outlined text-primary-fixed text-4xl"
                                                data-icon="school">school</span>
                                </div>
                                <h1 class="font-headline-md text-headline-md text-primary mb-xs">EduManage</h1>
                                <p class="font-body-sm text-body-sm text-on-surface-variant">Portal de Administração
                                        Escolar</p>
                        </div>
                        <!-- Login Form -->
                        <form class="px-xl pb-xl space-y-lg">
                                <!-- Username Field -->
                                <div class="space-y-xs">
                                        <label class="font-label-bold text-label-bold text-on-surface-variant block"
                                                for="username">
                                                USUÁRIO OU EMAIL
                                        </label>
                                        <div class="relative group">
                                                <div
                                                        class="absolute inset-y-0 left-0 pl-md flex items-center pointer-events-none">
                                                        <span class="material-symbols-outlined text-outline text-[20px]"
                                                                data-icon="person">person</span>
                                                </div>
                                                <input class="w-full h-10 pl-10 pr-md bg-white border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary-container focus:border-primary outline-none transition-all duration-200"
                                                        id="username" name="username"
                                                        placeholder="ex: joao.silva@escola.com" required=""
                                                        type="text" />
                                        </div>
                                </div>
                                <!-- Password Field -->
                                <div class="space-y-xs">
                                        <div class="flex justify-between items-center">
                                                <label class="font-label-bold text-label-bold text-on-surface-variant block"
                                                        for="password">
                                                        SENHA
                                                </label>
                                                <a class="font-label-sm text-label-sm text-primary hover:underline"
                                                        href="#">Esqueceu a senha?</a>
                                        </div>
                                        <div class="relative group">
                                                <div
                                                        class="absolute inset-y-0 left-0 pl-md flex items-center pointer-events-none">
                                                        <span class="material-symbols-outlined text-outline text-[20px]"
                                                                data-icon="lock">lock</span>
                                                </div>
                                                <input class="w-full h-10 pl-10 pr-md bg-white border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary-container focus:border-primary outline-none transition-all duration-200"
                                                        id="password" name="password" placeholder="••••••••" required=""
                                                        type="password" />
                                        </div>
                                </div>
                                <!-- Remember Me Checkbox -->
                                <div class="flex items-center space-x-sm">
                                        <input class="w-4 h-4 rounded-sm border-outline-variant text-primary focus:ring-primary"
                                                id="remember" type="checkbox" />
                                        <label class="font-body-sm text-body-sm text-on-surface-variant cursor-pointer"
                                                for="remember">Lembrar neste dispositivo</label>
                                </div>
                                <!-- Submit Button -->
                                <button class="w-full h-10 bg-primary text-on-primary font-label-bold text-label-bold rounded-lg hover:bg-primary-container active:scale-[0.98] transition-all duration-200 shadow-sm flex items-center justify-center gap-sm"
                                        type="submit">
                                        ENTRAR
                                        <span class="material-symbols-outlined text-[18px]"
                                                data-icon="login">login</span>
                                </button>
                        </form>
                        <!-- Footer Link -->
                        <div class="bg-surface-container-low px-xl py-md border-t border-outline-variant text-center">
                                <p class="font-body-sm text-body-sm text-on-surface-variant">
                                        Precisa de acesso? <a class="text-primary font-bold hover:underline"
                                                href="#">Solicite aqui</a>
                                </p>
                        </div>
                </div>
        </main>
        <!-- Page Footer -->
        <footer class="p-lg text-center">
                <div class="flex justify-center items-center gap-xl mb-sm">
                        <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors"
                                href="#">Termos de Uso</a>
                        <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors"
                                href="#">Política de Privacidade</a>
                        <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors"
                                href="#">Suporte</a>
                </div>
                <p class="font-label-sm text-label-sm text-outline-variant">© 2024 EduManage System. Todos os direitos
                        reservados.</p>
        </footer>
</body>

</html>