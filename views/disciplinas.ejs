<!DOCTYPE html>
<html class="light" lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Escola ABC - Gestão de Disciplinas</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        body { font-family: 'Inter', sans-serif; }
        .font-headline-md, .font-display-lg { font-family: 'Hanken Grotesk', sans-serif; }
</style>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#000e24",
                        "primary-container": "#00234b",
                        "on-primary": "#ffffff",
                        secondary: "#006d37",
                        "secondary-container": "#6bfe9c",
                        "on-secondary-container": "#00743a",
                        "surface": "#f6faff",
                        "surface-container": "#e6eff8",
                        "surface-container-low": "#ecf5fe",
                        "surface-container-highest": "#dbe4ed",
                        "surface-container-lowest": "#ffffff",
                        "on-surface": "#141d23",
                        "on-surface-variant": "#43474e",
                        "outline": "#74777f",
                        "outline-variant": "#c4c6d0",
                        error: "#ba1a1a",
                        "error-container": "#ffdad6"
                    },
                    spacing: { xs: "4px", sm: "8px", md: "16px", lg: "24px", xl: "32px", sidebar_width: "260px", header_height: "64px" }
                }
            }
        }
</script>
<%- include('partials/sidebar_css') %>
</head>
<body class="bg-background text-on-background min-h-screen overflow-x-hidden">
<%- include('partials/sidebar') %>
<header class="h-header_height fixed top-0 right-0 left-sidebar_width bg-surface flex justify-between items-center px-lg w-full z-10 border-b border-outline-variant">
<div class="flex items-center gap-md w-1/3">
<div class="relative w-full max-w-sm">
<span class="material-symbols-outlined absolute left-sm top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
<input class="w-full bg-surface-container-low border-none rounded-lg pl-[40px] pr-md py-[8px] text-[14px] focus:ring-2 focus:ring-primary/20" placeholder="Pesquisar..." type="text"/>
</div>
</div>
<div class="flex items-center gap-lg">
<div class="flex items-center gap-md">
<span class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:bg-surface-container-low p-xs rounded-full">notifications</span>
<span class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:bg-surface-container-low p-xs rounded-full">help_outline</span>
</div>
<div class="h-8 w-px bg-outline-variant"></div>
<div class="flex items-center gap-sm cursor-pointer">
<div class="text-right">
<p class="text-[12px] font-bold text-primary">Admin Usuário</p>
<p class="text-[10px] text-on-surface-variant uppercase tracking-wider">Diretoria</p>
</div>
<div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant"></div>
</div>
</div>
</header>
<main class="ml-sidebar_width pt-header_height min-h-screen bg-surface p-lg">
<div class="max-w-[1440px] mx-auto">
<header class="mb-xl">
<h2 class="font-display-lg text-[32px] font-bold text-primary">Gestão de Disciplinas</h2>
<p class="text-[14px] text-on-surface-variant">Configure as matérias para o ano letivo atual.</p>
</header>
<div class="grid grid-cols-12 gap-lg items-start">
<section class="col-span-12 lg:col-span-4 bg-surface-container-lowest p-lg rounded-xl border border-outline-variant">
<div class="flex items-center gap-sm mb-lg">
<span class="material-symbols-outlined text-secondary">add_box</span>
<h3 class="font-headline-md text-[24px] font-bold text-primary">Cadastro de Disciplina</h3>
</div>
<form class="space-y-lg">
<div class="space-y-xs">
<label class="text-[12px] font-bold text-on-surface-variant ml-xs">Nome da Disciplina</label>
<input class="w-full h-10 bg-white border border-outline-variant rounded-lg px-md focus:border-primary focus:ring-0 text-[14px]" placeholder="Ex: Matemática Avançada" type="text"/>
</div>
<div class="space-y-xs">
<label class="text-[12px] font-bold text-on-surface-variant ml-xs">Descrição</label>
<textarea class="w-full bg-white border border-outline-variant rounded-lg p-md focus:border-primary focus:ring-0 text-[14px] resize-none" rows="4" placeholder="Adicione uma breve descrição sobre a disciplina..."></textarea>
</div>
<div class="pt-md flex flex-col gap-sm">
<button class="w-full h-11 bg-primary text-on-primary rounded text-[12px] font-bold hover:opacity-90 flex justify-center items-center gap-xs" type="button">
<span class="material-symbols-outlined" style="font-size:18px">save</span> Salvar Disciplina
</button>
<button class="w-full h-11 bg-transparent border border-outline-variant text-primary rounded text-[12px] font-bold hover:bg-surface-container" type="reset">
Limpar Campos
</button>
</div>
</form>
<div class="mt-xl p-md bg-surface-container-low rounded border border-outline-variant flex items-center justify-between">
<div>
<p class="text-[11px] text-on-surface-variant uppercase font-semibold">Total Disciplinas</p>
<p class="text-[24px] font-bold text-primary">24</p>
</div>
<span class="material-symbols-outlined text-primary/40 text-[40px]">library_books</span>
</div>
</section>
<section class="col-span-12 lg:col-span-8 space-y-lg">
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden">
<div class="p-lg border-b border-outline-variant flex justify-between items-center flex-wrap gap-md">
<div class="flex items-center gap-sm">
<span class="material-symbols-outlined text-primary">format_list_bulleted</span>
<h3 class="text-[18px] font-bold text-primary">Lista de Disciplinas Ativas</h3>
</div>
<div class="flex items-center gap-sm">
<div class="relative w-64">
<span class="material-symbols-outlined absolute left-[8px] top-1/2 -translate-y-1/2 text-on-surface-variant text-[18px]">search</span>
<input class="w-full bg-white border border-outline-variant rounded-lg pl-[32px] pr-md py-xs text-[14px]" placeholder="Filtrar por nome..." type="text"/>
</div>
<button class="flex items-center gap-xs px-md py-[6px] bg-surface-container-low border border-outline-variant rounded text-[12px] font-bold hover:bg-surface-container transition-colors" onclick="window.print()">
<span class="material-symbols-outlined text-[18px]">download</span> Exportar Lista
</button>
</div>
</div>
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead class="bg-surface-container-high sticky top-0">
<tr>
<th class="px-lg py-md text-[12px] font-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Código</th>
<th class="px-lg py-md text-[12px] font-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Nome da Disciplina</th>
<th class="px-lg py-md text-[12px] font-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Descrição</th>
<th class="px-lg py-md text-[12px] font-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Status</th>
<th class="px-lg py-md text-[12px] font-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant text-right">Ações</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant">
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md text-[14px] text-on-surface-variant">MAT-01</td>
<td class="px-lg py-md text-[14px] text-primary font-medium flex items-center gap-sm"><span class="material-symbols-outlined text-[18px]">functions</span> Matemática I</td>
<td class="px-lg py-md text-[14px] text-on-surface-variant">Álgebra e Geometria Plana</td>
<td class="px-lg py-md"><span class="inline-flex items-center px-sm py-xs rounded-full bg-secondary-container text-on-secondary-container text-[11px] font-semibold">Ativa</span></td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all"><span class="material-symbols-outlined text-[18px]">edit</span></button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios'"><span class="material-symbols-outlined text-[18px]">visibility</span></button>
</td>
</tr>
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md text-[14px] text-on-surface-variant">POR-01</td>
<td class="px-lg py-md text-[14px] text-primary font-medium flex items-center gap-sm"><span class="material-symbols-outlined text-[18px]">translate</span> Língua Portuguesa</td>
<td class="px-lg py-md text-[14px] text-on-surface-variant">Gramática e Interpretação de Texto</td>
<td class="px-lg py-md"><span class="inline-flex items-center px-sm py-xs rounded-full bg-secondary-container text-on-secondary-container text-[11px] font-semibold">Ativa</span></td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all"><span class="material-symbols-outlined text-[18px]">edit</span></button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios'"><span class="material-symbols-outlined text-[18px]">visibility</span></button>
</td>
</tr>
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md text-[14px] text-on-surface-variant">HIS-02</td>
<td class="px-lg py-md text-[14px] text-primary font-medium flex items-center gap-sm"><span class="material-symbols-outlined text-[18px]">history_edu</span> História do Brasil</td>
<td class="px-lg py-md text-[14px] text-on-surface-variant">Período Colonial e Brasil Império</td>
<td class="px-lg py-md"><span class="inline-flex items-center px-sm py-xs rounded-full bg-secondary-container text-on-secondary-container text-[11px] font-semibold">Ativa</span></td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all"><span class="material-symbols-outlined text-[18px]">edit</span></button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios'"><span class="material-symbols-outlined text-[18px]">visibility</span></button>
</td>
</tr>
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md text-[14px] text-on-surface-variant">FIS-01</td>
<td class="px-lg py-md text-[14px] text-primary font-medium flex items-center gap-sm"><span class="material-symbols-outlined text-[18px]">bolt</span> Física I</td>
<td class="px-lg py-md text-[14px] text-on-surface-variant">Mecânica Clássica e Cinemática</td>
<td class="px-lg py-md"><span class="inline-flex items-center px-sm py-xs rounded-full bg-primary-fixed text-on-primary-fixed-variant text-[11px] font-semibold">Pendente</span></td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all"><span class="material-symbols-outlined text-[18px]">edit</span></button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios'"><span class="material-symbols-outlined text-[18px]">visibility</span></button>
</td>
</tr>
</tbody>
</table>
</div>
<div class="px-lg py-md bg-surface-container-low border-t border-outline-variant flex items-center justify-between">
<p class="text-[11px] text-on-surface-variant">Mostrando 4 de 24 disciplinas</p>
<div class="flex gap-xs">
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-on-surface-variant hover:bg-surface-container transition-colors disabled:opacity-50" disabled><span class="material-symbols-outlined text-[18px]">chevron_left</span></button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-primary text-on-primary text-[12px] font-bold">1</button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-primary text-[12px] font-bold hover:bg-surface-container transition-colors">2</button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-primary text-[12px] font-bold hover:bg-surface-container transition-colors">3</button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-on-surface-variant hover:bg-surface-container transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_right</span></button>
</div>
</div>
</div>
</section>
</div>
</div>
</main>
</body>
</html>
