<body class="bg-background text-on-background min-h-screen overflow-x-hidden">
<!-- SideNavBar -->
<%- include('partials/sidebar') %>
<!-- TopNavBar -->
<header class="h-header_height fixed top-0 right-0 left-sidebar_width bg-surface dark:bg-surface-dim flex justify-between items-center px-lg w-full z-10 border-b border-outline-variant">
<div class="flex items-center gap-md w-1/3">
</div>
<div class="flex items-center gap-lg">
<div class="flex items-center gap-md">
<span class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:bg-surface-container-low p-xs rounded-full" data-icon="notifications">notifications</span>
<span class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:bg-surface-container-low p-xs rounded-full" data-icon="help_outline">help_outline</span>
</div>
<div class="h-8 w-px bg-outline-variant"></div>
<div class="flex items-center gap-sm cursor-pointer active:opacity-80">
<div class="text-right">
<p class="font-label-bold text-label-bold text-primary">Admin Usuário</p>
<p class="text-[10px] text-on-surface-variant uppercase tracking-wider">Diretoria</p>
</div>
<img alt="Foto do Administrador" class="w-10 h-10 rounded-full bg-surface-container-high object-cover border border-outline-variant" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDJRdKuPgLF_d-UwuD6zCZmogARooqM1ggNenOwyuPse9Mn1lU-9l9Vhd0qqRSkqiMoSlX9ZpV_h3XZnMMn86Sg2oN6leUFantuXqNviin6y7yHiD5y3Ec95jYW2P91aeBz7nCkXPy1l5BtJDIVSco6l-ncTXT2UMPhusueRwQpvJmgJEIkLcSr5dZqKJEdeMDWqEkAhUmDidlQnFLo1n61sJpYHHEyh-FLqy0J1czjEQ83VkqljeSbat_KCQCqOyHn1uS5t7vPceE"/>
</div>
</div>
</header>
<!-- Main Content -->
<main class="ml-sidebar_width pt-header_height min-h-screen bg-background p-lg">
<div class="max-w-[1440px] mx-auto">
<header class="mb-xl">
<h2 class="font-display-lg text-display-lg text-primary">Gestão de Turmas</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Configure e gerencie as turmas ativas no sistema para o ano letivo corrente.</p>
</header>
<div class="grid grid-cols-12 gap-lg items-start">
<!-- Registration Form Section (Left) -->
<section class="col-span-12 lg:col-span-4 bg-surface-container-lowest p-lg rounded-xl border border-outline-variant">
<div class="flex items-center gap-sm mb-lg">
<span class="material-symbols-outlined text-secondary" data-icon="edit_note" style="font-variation-settings: 'FILL' 1;">edit_note</span>
<h3 class="font-headline-md text-headline-md text-primary">Cadastro de Turma</h3>
</div>
<form class="space-y-lg">
<div class="space-y-xs">
<label class="font-label-bold text-label-bold text-on-surface-variant ml-xs">Nome da Turma</label>
<input class="w-full h-10 bg-white border border-outline-variant rounded-lg px-md focus:border-primary focus:ring-0 transition-colors text-body-md" placeholder="Ex: 3º Ano A" type="text"/>
</div>
<div class="space-y-xs">
<label class="font-label-bold text-label-bold text-on-surface-variant ml-xs">Ano Acadêmico</label>
<input class="w-full h-10 bg-white border border-outline-variant rounded-lg px-md focus:border-primary focus:ring-0 transition-colors text-body-md" placeholder="Ex: 2024" type="number"/>
</div>

<div class="pt-md flex flex-col gap-sm">
<button class="w-full h-11 bg-primary text-on-primary rounded font-label-bold text-label-bold hover:opacity-90 transition-opacity" type="submit">
                                Salvar Alterações
                            </button>
<button class="w-full h-11 bg-transparent border border-outline-variant text-primary rounded font-label-bold text-label-bold hover:bg-surface-container transition-colors" type="reset">
                                Limpar Campos
                            </button>
</div>
</form>

</section>
<!-- List/Table Section (Right) -->
<section class="col-span-12 lg:col-span-8 space-y-lg">

<!-- Main Table -->
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden">
<div class="p-lg border-b border-outline-variant flex justify-between items-center">
<h3 class="font-title-sm text-title-sm text-primary">Lista de Turmas Ativas</h3>
<div class="flex gap-sm">
<button class="flex items-center gap-xs px-md py-sm bg-surface-container-low border border-outline-variant rounded font-label-bold text-label-bold hover:bg-surface-container transition-colors" onclick="alert('Abrindo filtros...')">
<span class="material-symbols-outlined text-lg" data-icon="filter_list">filter_list</span> Filtrar
                                </button>
<button class="flex items-center gap-xs px-md py-sm bg-surface-container-low border border-outline-variant rounded font-label-bold text-label-bold hover:bg-surface-container transition-colors" onclick="window.print()">
<span class="material-symbols-outlined text-lg" data-icon="download">download</span> Exportar
                                </button>
</div>
</div>
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead class="bg-surface-container-high sticky top-0">
<tr>
<th class="px-lg py-md text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Nome da Turma</th>
<th class="px-lg py-md text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Ano Letivo</th>
<th class="px-lg py-md text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Status</th>
<th class="px-lg py-md text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant text-right">Ações</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant">
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md font-body-md text-primary font-medium">1º Ano A - Ensino Médio</td>
<td class="px-lg py-md font-body-md text-on-surface-variant">2024</td>
<td class="px-lg py-md">
<span class="inline-flex items-center px-sm py-xs rounded-full bg-secondary-container text-on-secondary-container text-label-sm font-semibold">
                                                Confirmado
                                            </span>
</td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all">
<span class="material-symbols-outlined" data-icon="edit">edit</span>
</button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios?report=notas_turma_disc'">
<span class="material-symbols-outlined" data-icon="visibility">visibility</span>
</button>
</td>
</tr>
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md font-body-md text-primary font-medium">2º Ano B - Ensino Médio</td>
<td class="px-lg py-md font-body-md text-on-surface-variant">2024</td>
<td class="px-lg py-md">
<span class="inline-flex items-center px-sm py-xs rounded-full bg-secondary-container text-on-secondary-container text-label-sm font-semibold">
                                                Confirmado
                                            </span>
</td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all">
<span class="material-symbols-outlined" data-icon="edit">edit</span>
</button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios?report=notas_turma_disc'">
<span class="material-symbols-outlined" data-icon="visibility">visibility</span>
</button>
</td>
</tr>
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md font-body-md text-primary font-medium">3º Ano A - Fundamental</td>
<td class="px-lg py-md font-body-md text-on-surface-variant">2023</td>
<td class="px-lg py-md">
<span class="inline-flex items-center px-sm py-xs rounded-full bg-surface-container-highest text-on-surface-variant text-label-sm font-semibold">
                                                Encerrado
                                            </span>
</td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all">
<span class="material-symbols-outlined" data-icon="edit">edit</span>
</button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios?report=notas_turma_disc'">
<span class="material-symbols-outlined" data-icon="visibility">visibility</span>
</button>
</td>
</tr>
<tr class="hover:bg-surface-container-low transition-colors group">
<td class="px-lg py-md font-body-md text-primary font-medium">Turma Especial - Robótica</td>
<td class="px-lg py-md font-body-md text-on-surface-variant">2024</td>
<td class="px-lg py-md">
<span class="inline-flex items-center px-sm py-xs rounded-full bg-primary-fixed text-on-primary-fixed-variant text-label-sm font-semibold">
                                                Pendente
                                            </span>
</td>
<td class="px-lg py-md text-right space-x-xs">
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all">
<span class="material-symbols-outlined" data-icon="edit">edit</span>
</button>
<button class="p-xs text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded transition-all" onclick="window.location.href='/relatorios?report=notas_turma_disc'">
<span class="material-symbols-outlined" data-icon="visibility">visibility</span>
</button>
</td>
</tr>
</tbody>
</table>
</div>
<!-- Table Pagination -->
<div class="px-lg py-md bg-surface-container-low border-t border-outline-variant flex items-center justify-between">
<p class="text-label-sm text-on-surface-variant">Exibindo 1-4 de 12 turmas</p>
<div class="flex gap-xs">
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-on-surface-variant hover:bg-surface-container transition-colors disabled:opacity-50" disabled="">
<span class="material-symbols-outlined text-lg" data-icon="chevron_left">chevron_left</span>
</button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-primary text-on-primary font-label-bold">1</button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-primary font-label-bold hover:bg-surface-container transition-colors">2</button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-primary font-label-bold hover:bg-surface-container transition-colors">3</button>
<button class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded bg-white text-on-surface-variant hover:bg-surface-container transition-colors">
<span class="material-symbols-outlined text-lg" data-icon="chevron_right">chevron_right</span>
</button>
</div>
</div>
</div>
</section>
</div>
</div>
</main>
</body></html>