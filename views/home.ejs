<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Escola ABC - Dashboard Administrativo</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <%- include('partials/sidebar_css') %>
</head>
<body>

    <%- include('partials/sidebar') %>

    <main class="main-content">
        
        <header class="top-header">
            <div class="user-info">
                <span>Portal Administrativo</span>
                <i class="far fa-bell"></i>
                <i class="far fa-question-circle"></i>
                <div class="profile">
                    <div class="profile-text">
                        <strong>Admin User</strong>
                        <small>SUPER ADMINISTRADOR</small>
                    </div>
                    <div class="avatar"></div>
                </div>
            </div>
        </header>



        <section class="metrics-grid">
            <div class="card metric">
                <div class="metric-header">
                    <i class="fas fa-user-graduate"></i>
                    <span class="badge positive">+4% est.</span>
                </div>
                <small>TOTAL DE ALUNOS</small>
                <h3>1,284</h3>
                <div class="metric-footer">Ativos: 1,240 <i class="fas fa-arrow-right"></i></div>
            </div>
            <div class="card metric">
                <div class="metric-header">
                    <i class="fas fa-user-tie"></i>
                    <span class="badge neutral">Estável</span>
                </div>
                <small>CORPO DOCENTE</small>
                <h3>86</h3>
                <div class="metric-footer">Em aula: 42 <i class="fas fa-arrow-right"></i></div>
            </div>
            <div class="card metric">
                <div class="metric-header">
                    <i class="fas fa-users"></i>
                    <span class="badge warning">Lotação Alta</span>
                </div>
                <small>TURMAS ATIVAS</small>
                <h3>48</h3>
                <div class="metric-footer">Período: Integral <i class="fas fa-arrow-right"></i></div>
            </div>
        </section>

        <div class="bottom-grid">
            <section class="card table-container">
                <div class="card-header">
                    <h3>Matrículas Recentes</h3>
                    <a href="#">Ver todos</a>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>ALUNO</th>
                            <th>TURMA</th>
                            <th>DATA</th>
                            <th>STATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Mariana Almeida</strong></td>
                            <td>3º Ano A - Médio</td>
                            <td>12 Mai, 2024</td>
                            <td><span class="status approved">APROVADO</span></td>
                        </tr>
                        <tr>
                            <td><strong>Ricardo Costa</strong></td>
                            <td>9º Ano B - Fund.</td>
                            <td>11 Mai, 2024</td>
                            <td><span class="status pending">PENDENTE</span></td>
                        </tr>
                        <tr>
                            <td><strong>Julia Santos</strong></td>
                            <td>1º Ano C - Médio</td>
                            <td>10 Mai, 2024</td>
                            <td><span class="status approved">APROVADO</span></td>
                        </tr>
                        <tr>
                            <td><strong>Bruno Torres</strong></td>
                            <td>2º Ano A - Médio</td>
                            <td>08 Mai, 2024</td>
                            <td><span class="status cancelled">CANCELADO</span></td>
                        </tr>
                    </tbody>
                </table>
            </section>

            <aside class="widgets">
                <div class="card events">
                    <h3 style="margin-bottom: 15px;">Calendário & Eventos</h3>
                    
                    <!-- Calendário Intuitivo -->
                    <div style="margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #eee;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <button style="background: none; border: none; cursor: pointer; color: #555;"><i class="fas fa-chevron-left"></i></button>
                            <h4 style="margin: 0; font-size: 14px; color: #333;">Maio 2024</h4>
                            <button style="background: none; border: none; cursor: pointer; color: #555;"><i class="fas fa-chevron-right"></i></button>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; text-align: center; font-size: 12px; font-weight: 600; color: #888; margin-bottom: 8px;">
                            <div>D</div><div>S</div><div>T</div><div>Q</div><div>Q</div><div>S</div><div>S</div>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; text-align: center; font-size: 13px; color: #444;">
                            <div style="color: #ccc;">28</div><div style="color: #ccc;">29</div><div style="color: #ccc;">30</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">1</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">2</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">3</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">4</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">5</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">6</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">7</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">8</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">9</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">10</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">11</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">12</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">13</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">14</div>
                            <div style="background-color: #00a859; color: white; padding: 4px 0; cursor: pointer; border-radius: 4px; font-weight: bold; box-shadow: 0 2px 4px rgba(0,168,89,0.3);">15</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">16</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">17</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">18</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">19</div>
                            <div style="background-color: #f0ad4e; color: white; padding: 4px 0; cursor: pointer; border-radius: 4px; font-weight: bold; box-shadow: 0 2px 4px rgba(240,173,78,0.3);">20</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">21</div>
                            <div style="background-color: #e6f7ff; color: #0066cc; padding: 4px 0; cursor: pointer; border-radius: 4px; font-weight: bold; border: 1px solid #91d5ff;">22</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">23</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">24</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">25</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">26</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">27</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">28</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">29</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">30</div>
                            <div style="padding: 4px 0; cursor: pointer; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='transparent'">31</div>
                            <div style="color: #ccc;">1</div>
                        </div>
                    </div>

                    <h4 style="margin-bottom: 10px; font-size: 13px; color: #666; text-transform: uppercase; letter-spacing: 0.5px;">Próximos</h4>
                    <div class="event-item">
                        <div class="date-box" style="background: rgba(0,168,89,0.1); color: #00a859;"><span>MAI</span><strong>15</strong></div>
                        <div class="event-info"><strong>Reunião Pedagógica</strong><small>14:00 - Auditório Principal</small></div>
                    </div>
                    <div class="event-item">
                        <div class="date-box" style="background: rgba(240,173,78,0.1); color: #f0ad4e;"><span>MAI</span><strong>20</strong></div>
                        <div class="event-info"><strong>Conselho de Classe</strong><small>08:30 - Sala 402</small></div>
                    </div>
                    <button class="btn-outline" style="margin-top: 10px; width: 100%;">Adicionar Evento</button>
                </div>
            </aside>
        </div>
    </main>

</body>
</html>