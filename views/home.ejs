<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Escola ABC - Dashboard Administrativo</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        corePlugins: { preflight: false },
        theme: {
          extend: {
            colors: {
              "surface": "#f6faff",
              "surface-dim": "#d2dbe4",
              "outline-variant": "#c4c6d0",
              "surface-container-low": "#ecf5fe",
              "on-surface-variant": "#43474e",
              "primary": "#000e24",
              "surface-container-high": "#e0e9f2"
            },
            spacing: { "md": "16px", "lg": "24px", "sm": "8px", "xs": "4px", "header_height": "64px", "sidebar_width": "260px" },
          }
        }
      }
    </script>
    <%- include('partials/sidebar_css') %>
</head>
<body>

    <%- include('partials/sidebar') %>

    <main class="main-content">
        
        <%- include('partials/top_header') %>

        <section class="welcome-section">
            <div class="welcome-text">
                <h1>Bem-vindo, Administrador</h1>
            </div>
            <div class="welcome-chart-placeholder">
                <i class="fas fa-chart-bar"></i>
            </div>
        </section>

        <section class="metrics-grid">
            <div class="card metric">
                <div class="metric-header">
                    <i class="fas fa-user-graduate"></i>
                    <span class="badge positive">+4% est.</span>
                </div>
                <small>TOTAL DE ALUNOS</small>
                <h3><%= totalAlunos %></h3>
                <div class="metric-footer">Ativos: <%= totalAlunos %> <i class="fas fa-arrow-right"></i></div>
            </div>
            <div class="card metric">
                <div class="metric-header">
                    <i class="fas fa-user-tie"></i>
                    <span class="badge neutral">Estável</span>
                </div>
                <small>CORPO DOCENTE</small>
                <h3><%= totalProfessores %></h3>
                <div class="metric-footer">Cadastrados: <%= totalProfessores %> <i class="fas fa-arrow-right"></i></div>
            </div>
            <div class="card metric">
                <div class="metric-header">
                    <i class="fas fa-users"></i>
                    <span class="badge warning">Lotação Alta</span>
                </div>
                <small>TURMAS ATIVAS</small>
                <h3><%= totalTurmas %></h3>
                <div class="metric-footer">Ano letivo atual <i class="fas fa-arrow-right"></i></div>
            </div>
        </section>

        <div class="bottom-grid">
            <section class="card table-container">
                <div class="card-header">
                    <h3>Matrículas Recentes</h3>
                    <a href="#">Ver todos</a>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>ALUNO</th>
                            <th>TURMA</th>
                            <th>DATA</th>
                            <th>STATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Mariana Almeida</strong></td>
                            <td>3º Ano A - Médio</td>
                            <td>12 Mai, 2024</td>
                            <td><span class="status approved">APROVADO</span></td>
                        </tr>
                        <tr>
                            <td><strong>Ricardo Costa</strong></td>
                            <td>9º Ano B - Fund.</td>
                            <td>11 Mai, 2024</td>
                            <td><span class="status pending">PENDENTE</span></td>
                        </tr>
                        <tr>
                            <td><strong>Julia Santos</strong></td>
                            <td>1º Ano C - Médio</td>
                            <td>10 Mai, 2024</td>
                            <td><span class="status approved">APROVADO</span></td>
                        </tr>
                        <tr>
                            <td><strong>Bruno Torres</strong></td>
                            <td>2º Ano A - Médio</td>
                            <td>08 Mai, 2024</td>
                            <td><span class="status cancelled">CANCELADO</span></td>
                        </tr>
                    </tbody>
                </table>
            </section>
        </div>
    </main>

</body>
</html>