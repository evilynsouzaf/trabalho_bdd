            <label class="block font-label-bold text-label-bold text-on-surface-variant mb-xs">Turma</label>
            <div class="relative">
                <select id="select-turma" class="w-full h-[40px] px-md border border-outline-variant rounded bg-white text-body-md focus:ring-1 focus:ring-primary focus:border-primary appearance-none cursor-pointer">
