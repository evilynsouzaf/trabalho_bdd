                <span class="material-symbols-outlined text-[18px]">search</span> Gerar
            </button>
        </div>
    </div>
</div>

<script>
function updateFilters() {
    const type = document.getElementById('reportType').value;
    const fTurma = document.getElementById('filter-turma');
    const fDisc = document.getElementById('filter-disciplina');
    const fAluno = document.getElementById('filter-aluno');
    const fProf = document.getElementById('filter-professor');
    const selTurma = document.getElementById('select-turma');

    // Reset visibilidade
    fTurma.classList.add('hidden');
    fDisc.classList.add('hidden');
    fAluno.classList.add('hidden');
    fProf.classList.add('hidden');
    
    if (type === 'notas_aluno') {
        fTurma.classList.remove('hidden');
        fAluno.classList.remove('hidden');
        selTurma.options[0].text = "Geral (Toda a Escola)";
    } else if (type === 'notas_turma_disc') {
        fTurma.classList.remove('hidden');
        fDisc.classList.remove('hidden');
        selTurma.options[0].text = "Selecione a Turma";
    } else if (type === 'alunos_turma') {
        fTurma.classList.remove('hidden');
        selTurma.options[0].text = "Selecione a Turma";
    } else if (type === 'aprovados_reprovados') {
        fTurma.classList.remove('hidden');
        fDisc.classList.remove('hidden');
        selTurma.options[0].text = "Selecione a Turma";
    } else if (type === 'disc_professor') {
        fProf.classList.remove('hidden');
        fDisc.classList.remove('hidden');
    }
}

window.onload = () => {
    const urlParams = new URLSearchParams(window.location.search);
    const report = urlParams.get('report');
    if (report) {
        const reportTypeEl = document.getElementById('reportType');
        if (reportTypeEl) reportTypeEl.value = report;
    }
    updateFilters();
};
</script>
