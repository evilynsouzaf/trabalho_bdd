        <script>
            // Input masks for a premium feel
            const cpfInput = document.querySelector('input[name="CPF"]');
            cpfInput.addEventListener('input', function (e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length > 11) value = value.slice(0, 11);
                if (value.length > 9) {
                    value = value.replace(/^(\d{3})(\d{3})(\d{3})(\d{2})$/, '$1.$2.$3-$4');
                } else if (value.length > 6) {
                    value = value.replace(/^(\d{3})(\d{3})(\d{0,3})$/, '$1.$2.$3');
                } else if (value.length > 3) {
                    value = value.replace(/^(\d{3})(\d{0,3})$/, '$1.$2');
                }
                e.target.value = value;
            });

            const celInput = document.querySelector('input[name="celular"]');
            celInput.addEventListener('input', function (e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length > 11) value = value.slice(0, 11);
                if (value.length > 6) {
                    value = value.replace(/^(\d{2})(\d{5})(\d{0,4})$/, '($1) $2-$3');
                } else if (value.length > 2) {
                    value = value.replace(/^(\d{2})(\d{0,5})$/, '($1) $2');
                } else if (value.length > 0) {
                    value = value.replace(/^(\d{0,2})$/, '($1');
                }
                e.target.value = value;
            });

            const cepInput = document.querySelector('input[name="CEP"]');
            cepInput.addEventListener('input', function (e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length > 8) value = value.slice(0, 8);
                if (value.length > 5) {
                    value = value.replace(/^(\d{5})(\d{0,3})$/, '$1-$2');
                }
                e.target.value = value;
            });

            // Handle form submit
            const form = document.getElementById('student-form');
            const btnSubmitTop = document.getElementById('btn-submit-top');

            if (btnSubmitTop) {
                btnSubmitTop.addEventListener('click', () => {
                    if (form.reportValidity()) {
                        form.requestSubmit();
                    }
                });
            }

            form.addEventListener('submit', async function (e) {
                e.preventDefault();

                // Get action buttons
                const submitBtnBottom = form.querySelector('button[type="submit"]');
                const originalBtnBottomText = submitBtnBottom.innerHTML;
                const originalBtnTopText = btnSubmitTop ? btnSubmitTop.innerHTML : '';

                // Disable buttons and show loading spinner
                submitBtnBottom.disabled = true;
                if (btnSubmitTop) btnSubmitTop.disabled = true;

                const loadingSpinner = `
            <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Enviando...
        `;

                submitBtnBottom.innerHTML = loadingSpinner;
                if (btnSubmitTop) btnSubmitTop.innerHTML = loadingSpinner;

                // Clear previous alert if exists
                const oldAlert = document.getElementById('feedback-alert');
                if (oldAlert) oldAlert.remove();

                // Build request payload
                const formData = new FormData(form);
                const payload = {};
                formData.forEach((value, key) => {
                    payload[key] = value;
                });

                try {
                    const response = await fetch('/alunos/novo', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(payload)
                    });

                    const result = await response.json();

                    if (response.ok && result.success) {
                        showFeedback('Aluno cadastrado com sucesso! Redirecionando para listagem...', 'success');
                        setTimeout(() => {
                            window.location.href = '/alunos';
                        }, 2000);
                    } else {
                        showFeedback(result.error || 'Erro desconhecido ao cadastrar aluno.', 'error');
                        // Restore buttons
                        submitBtnBottom.disabled = false;
                        submitBtnBottom.innerHTML = originalBtnBottomText;
                        if (btnSubmitTop) {
                            btnSubmitTop.disabled = false;
                            btnSubmitTop.innerHTML = originalBtnTopText;
                        }
                    }
                } catch (error) {
                    console.error('Submit error:', error);
                    showFeedback('Erro de comunicação com o servidor. Tente novamente.', 'error');
                    // Restore buttons
                    submitBtnBottom.disabled = false;
                    submitBtnBottom.innerHTML = originalBtnBottomText;
                    if (btnSubmitTop) {
                        btnSubmitTop.disabled = false;
                        btnSubmitTop.innerHTML = originalBtnTopText;
                    }
                }
            });

            function showFeedback(message, type) {
                const alertDiv = document.createElement('div');
                alertDiv.id = 'feedback-alert';

                let bgClass, borderClass, textClass, icon;
                if (type === 'success') {
                    bgClass = 'bg-secondary-container';
                    borderClass = 'border-secondary/20';
                    textClass = 'text-on-secondary-container';
                    icon = 'check_circle';
                } else {
                    bgClass = 'bg-error-container';
                    borderClass = 'border-error/20';
                    textClass = 'text-on-error-container';
                    icon = 'error';
                }

                alertDiv.className = `p-md rounded-lg mb-lg flex items-center gap-sm font-body-md border transition-all ${bgClass} ${borderClass} ${textClass}`;
                alertDiv.innerHTML = `
            <span class="material-symbols-outlined">${icon}</span>
            <span>${message}</span>
        `;

                // Insert alert right at the start of the form
                form.insertBefore(alertDiv, form.firstChild);
                alertDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        </script>
</body>

</html>