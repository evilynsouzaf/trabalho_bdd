<!DOCTYPE html>

<html lang="pt-BR"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Hanken+Grotesk:wght@600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f6faff;
        }
        
        /* Sidebar Styles imported from home.html */
        :root {
            --sidebar-blue: #0b1421;
            --accent-green: #00a859;
            --text-white: #ffffff;
        }
        .sidebar { width: 260px; background-color: var(--sidebar-blue); color: var(--text-white); padding: 25px; display: flex; flex-direction: column; position: fixed; height: 100vh; left: 0; top: 0; box-sizing: border-box; z-index: 50; }
        .sidebar .logo { display: flex; align-items: center; gap: 12px; margin-bottom: 40px; }
        .sidebar .logo i { font-size: 28px; color: #90cdf4; }
        .sidebar .logo h2 { font-size: 18px; letter-spacing: 1px; margin: 0; font-family: 'Segoe UI', sans-serif;}
        .sidebar .logo span { font-size: 10px; opacity: 0.6; }
        .sidebar .menu ul { list-style: none; padding: 0; margin: 0; }
        .sidebar .menu li { padding: 12px 15px; margin-bottom: 5px; border-radius: 6px; cursor: pointer; opacity: 0.7; transition: 0.3s; font-size: 14px; display: block; }
        .sidebar .menu li:hover, .sidebar .menu li.active { background-color: rgba(255,255,255,0.1); opacity: 1; }
        .sidebar .menu li i { margin-right: 12px; width: 20px; text-align: center; }
        .sidebar .sidebar-footer { margin-top: auto; }
        .sidebar .btn-new { width: 100%; background-color: var(--accent-green); color: white; border: none; padding: 12px; border-radius: 6px; font-weight: bold; margin-bottom: 20px; cursor: pointer; }
        .sidebar .sidebar-footer ul { list-style: none; font-size: 13px; opacity: 0.7; padding: 0; }
        .sidebar .sidebar-footer li { margin-bottom: 10px; cursor: pointer; }
    </style>
<script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-secondary-container": "#00743a",
                      "surface-container": "#e6eff8",
                      "surface-container-lowest": "#ffffff",
                      "outline-variant": "#c4c6d0",
                      "surface-container-high": "#e0e9f2",
                      "tertiary": "#0c0e0f",
                      "secondary-container": "#6bfe9c",
                      "on-surface-variant": "#43474e",
                      "on-surface": "#141d23",
                      "on-error": "#ffffff",
                      "on-tertiary-container": "#898b8c",
                      "primary": "#000e24",
                      "secondary-fixed-dim": "#4ae183",
                      "secondary-fixed": "#6bfe9c",
                      "outline": "#74777f",
                      "tertiary-fixed-dim": "#c5c7c8",
                      "secondary": "#006d37",
                      "on-secondary-fixed-variant": "#005228",
                      "surface-container-low": "#ecf5fe",
                      "on-tertiary-fixed-variant": "#454748",
                      "on-tertiary-fixed": "#191c1d",
                      "on-secondary": "#ffffff",
                      "on-background": "#141d23",
                      "tertiary-container": "#212425",
                      "surface-variant": "#dbe4ed",
                      "on-error-container": "#93000a",
                      "inverse-surface": "#293138",
                      "on-secondary-fixed": "#00210c",
                      "on-primary-fixed-variant": "#2c4771",
                      "primary-fixed": "#d6e3ff",
                      "tertiary-fixed": "#e1e3e4",
                      "surface": "#f6faff",
                      "on-primary-fixed": "#001b3d",
                      "primary-container": "#00234b",
                      "on-primary": "#ffffff",
                      "surface-bright": "#f6faff",
                      "primary-fixed-dim": "#adc7f8",
                      "on-tertiary": "#ffffff",
                      "inverse-primary": "#adc7f8",
                      "surface-container-highest": "#dbe4ed",
                      "surface-tint": "#455f8a",
                      "on-primary-container": "#718bb9",
                      "surface-dim": "#d2dbe4",
                      "inverse-on-surface": "#e9f2fb",
                      "error": "#ba1a1a",
                      "background": "#f6faff",
                      "error-container": "#ffdad6"
              },
              "borderRadius": {
                      "DEFAULT": "0.125rem",
                      "lg": "0.25rem",
                      "xl": "0.5rem",
                      "full": "0.75rem"
              },
              "spacing": {
                      "unit": "4px",
                      "xs": "4px",
                      "sidebar_width": "260px",
                      "gutter": "16px",
                      "sm": "8px",
                      "md": "16px",
                      "header_height": "64px",
                      "xl": "32px",
                      "lg": "24px"
              },
              "fontFamily": {
                      "body-md": ["Inter"],
                      "title-sm": ["Inter"],
                      "label-sm": ["Inter"],
                      "display-lg": ["Hanken Grotesk"],
                      "headline-md": ["Hanken Grotesk"],
                      "label-bold": ["Inter"],
                      "body-sm": ["Inter"]
              },
              "fontSize": {
                      "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                      "title-sm": ["18px", {"lineHeight": "24px", "fontWeight": "600"}],
                      "label-sm": ["11px", {"lineHeight": "14px", "fontWeight": "500"}],
                      "display-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                      "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                      "label-bold": ["12px", {"lineHeight": "16px", "fontWeight": "600"}],
                      "body-sm": ["13px", {"lineHeight": "18px", "fontWeight": "400"}]
              }
            },
          },
        }
    </script>
    <%- include('partials/sidebar_css') %>
</head>
<body class="bg-background text-on-background">
<!-- SideNavBar -->
<%- include('partials/sidebar') %>
<!-- Main Content Area -->
<main class="ml-sidebar_width min-h-screen">
<!-- TopNavBar -->
<%- include('partials/top_header') %>
<!-- Content Canvas -->
<div class="pt-header_height p-lg max-w-[1400px] mx-auto">
<div class="mb-lg flex justify-between items-end">
<div>
<h2 class="font-display-lg text-display-lg text-primary">Gestão de Alunos</h2>
<p class="text-on-surface-variant font-body-md text-body-md">Visualize, cadastre e gerencie a base de estudantes da instituição.</p>
</div>
<button onclick="window.location.href='/alunos/novo'" class="bg-primary text-on-primary px-lg py-md rounded font-label-bold text-label-bold hover:opacity-90 transition-opacity flex items-center shadow-sm">
<span class="material-symbols-outlined mr-sm text-body-md">person_add</span>
                    Novo Cadastro
                </button>
</div>
<!-- Bento Layout Grid -->
<div class="grid grid-cols-12 gap-lg">
<!-- Left Column: Filter -->
<div class="col-span-12 lg:col-span-4 space-y-lg">
<div class="bg-surface-container-lowest border border-outline-variant p-lg rounded-lg shadow-sm">
<div class="flex items-center mb-md pb-sm border-b border-outline-variant">
<span class="material-symbols-outlined text-primary mr-sm" data-icon="filter_list">filter_list</span>
<h3 class="font-title-sm text-title-sm text-primary">Filtros de Aluno</h3>
</div>
<div class="space-y-md">
<div class="space-y-xs">
<label class="font-label-bold text-label-bold text-on-surface-variant block">Nome do Aluno</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]" data-icon="search">search</span>
<input id="filter-nome" class="w-full h-[40px] pl-10 pr-md border border-outline rounded focus:ring-0 focus:border-primary font-body-md" placeholder="Filtrar por nome..." type="text"/>
</div>
</div>
<div class="space-y-xs">
<label class="font-label-bold text-label-bold text-on-surface-variant block">Matrícula</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]" data-icon="search">search</span>
<input id="filter-matricula" class="w-full h-[40px] pl-10 pr-md border border-outline rounded focus:ring-0 focus:border-primary font-body-md" placeholder="Filtrar por matrícula..." type="text"/>
</div>
</div>
</div>
</div>
<!-- Statistics Card (Bento Style) -->
<div class="bg-primary text-on-primary p-lg rounded-lg flex justify-between items-center">
<div>
<p class="text-label-sm opacity-80 uppercase tracking-wider">Total de Alunos</p>
<h4 id="total-alunos-count" class="text-display-lg font-display-lg"><%= totalAlunos %></h4>
</div>
<div class="bg-secondary-fixed text-on-secondary-fixed p-md rounded-full">
<span class="material-symbols-outlined text-headline-md" data-icon="trending_up">trending_up</span>
</div>
</div>
</div>
<!-- Right Column: DataGridView -->
<div class="col-span-12 lg:col-span-8">
<div class="bg-surface-container-lowest border border-outline-variant rounded-lg shadow-sm overflow-hidden h-full flex flex-col">
<div class="p-lg border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
<div class="flex items-center">
<span class="material-symbols-outlined text-primary mr-sm" data-icon="list_alt">list_alt</span>
<h3 class="font-title-sm text-title-sm text-primary">Listagem de Matriculados</h3>
</div>
<div class="flex space-x-sm">
<button class="p-xs hover:bg-surface-container-high rounded text-on-surface-variant" title="Imprimir Lista">
<span class="material-symbols-outlined">print</span>
</button>
<button class="p-xs hover:bg-surface-container-high rounded text-on-surface-variant" title="Exportar CSV">
<span class="material-symbols-outlined">download</span>
</button>
</div>
</div>
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead class="bg-surface-container-high sticky top-0">
<tr>
<th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Matrícula</th>
<th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Nome do Aluno</th>
<th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Turma</th>
<th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant">Status</th>
<th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant text-right">Ações</th>
</tr>
</thead>
<tbody id="alunos-table-body" class="divide-y divide-outline-variant">
<!-- Preenchido via JavaScript -->
</tbody>
</table>
</div>
<!-- Pagination -->
<div class="mt-auto p-md border-t border-outline-variant bg-surface-container-lowest flex justify-between items-center px-lg">
<span id="pagination-status" class="text-label-sm text-on-surface-variant">Carregando alunos...</span>
<div id="pagination-buttons" class="flex items-center space-x-xs">
<!-- Botões de página dinâmicos -->
</div>
</div>
</div>
</div>
</div>
</div>
</main>

<script>
    let currentPage = 1;
    let debounceTimer;

    const filterNome = document.getElementById('filter-nome');
    const filterMatricula = document.getElementById('filter-matricula');
    const tableBody = document.getElementById('alunos-table-body');
    const paginationStatus = document.getElementById('pagination-status');
    const paginationButtons = document.getElementById('pagination-buttons');

    // Função para buscar alunos da API
    async function loadAlunos(page = 1) {
        currentPage = page;
        const nome = filterNome.value;
        const matricula = filterMatricula.value;

        paginationStatus.textContent = 'Carregando...';

        try {
            const response = await fetch(`/api/alunos?page=${page}&nome=${encodeURIComponent(nome)}&matricula=${encodeURIComponent(matricula)}`);
            const data = await response.json();

            if (response.ok) {
                renderTable(data.alunos);
                renderPagination(data.currentPage, data.totalPages, data.totalAlunos);
            } else {
                tableBody.innerHTML = `<tr><td colspan="5" class="px-lg py-md text-center text-error">Erro ao carregar dados do servidor.</td></tr>`;
            }
        } catch (error) {
            console.error('Erro ao buscar alunos:', error);
            tableBody.innerHTML = `<tr><td colspan="5" class="px-lg py-md text-center text-error">Erro de rede ao buscar dados.</td></tr>`;
        }
    }

    // Função para renderizar as linhas da tabela
    function renderTable(alunos) {
        if (!alunos || alunos.length === 0) {
            tableBody.innerHTML = `
                <tr>
                    <td colspan="5" class="px-lg py-xl text-center text-on-surface-variant font-body-md">
                        Nenhum aluno encontrado para os filtros aplicados.
                    </td>
                </tr>
            `;
            return;
        }

        tableBody.innerHTML = alunos.map(aluno => {
            // Obter as iniciais do aluno para o avatar
            const names = aluno.aluno_nome.trim().split(/\\s+/);
            const initials = names.length > 1 
                ? (names[0][0] + names[names.length - 1][0]).toUpperCase()
                : names[0][0].toUpperCase();

            // Status formatado (Ativo = 1, Inativo = 0)
            const statusLabel = aluno.aluno_status ? 'Ativo' : 'Inativo';
            const statusClass = aluno.aluno_status 
                ? 'bg-[#e6fcf5] text-[#006d37]' 
                : 'bg-[#f8d7da] text-[#721c24]'; // Customizado para premium inativo (leve vermelho)

            const turmaLabel = aluno.turma_nome || 'Sem Turma';

            return `
                <tr class="hover:bg-surface-container-low transition-colors group">
                    <td class="px-lg py-md font-body-sm text-body-sm text-on-surface-variant">#${aluno.aluno_matricula}</td>
                    <td class="px-lg py-md">
                        <div class="flex items-center space-x-sm">
                            <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center text-primary font-bold text-[10px]">
                                ${initials}
                            </div>
                            <span class="font-body-md text-body-md text-primary">${aluno.aluno_nome}</span>
                        </div>
                    </td>
                    <td class="px-lg py-md font-body-sm text-body-sm text-on-surface-variant">${turmaLabel}</td>
                    <td class="px-lg py-md">
                        <span class="${statusClass} px-sm py-1 rounded-full text-[10px] font-bold uppercase tracking-tight">
                            ${statusLabel}
                        </span>
                    </td>
                    <td class="px-lg py-md text-right">
                        <div class="flex justify-end space-x-sm opacity-60 group-hover:opacity-100 transition-opacity">
                            <button class="p-xs hover:bg-surface-container-high rounded text-primary" title="Editar">
                                <span class="material-symbols-outlined text-body-md">edit</span>
                            </button>
                            <button class="p-xs hover:bg-error-container rounded text-error" title="Excluir">
                                <span class="material-symbols-outlined text-body-md">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');
    }

    // Função para renderizar os botões de paginação
    function renderPagination(currentPage, totalPages, totalAlunos) {
        // Atualiza texto de status (100 por página)
        const limit = 100;
        const start = totalAlunos === 0 ? 0 : (currentPage - 1) * limit + 1;
        const end = Math.min(currentPage * limit, totalAlunos);
        paginationStatus.textContent = `Exibindo ${start}-${end} de ${totalAlunos.toLocaleString('pt-BR')} alunos`;

        let buttonsHtml = '';

        // Botão Anterior (Chevron Left)
        const prevDisabled = currentPage === 1 ? 'disabled' : '';
        buttonsHtml += `
            <button onclick="if(currentPage > 1) loadAlunos(currentPage - 1)" 
                    class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded hover:bg-surface-container-low disabled:opacity-30" 
                    \${prevDisabled}>
                <span class="material-symbols-outlined text-body-md">chevron_left</span>
            </button>
        `;

        // Regras para mostrar páginas (exibir vizinhos próximos e elipses se houver muitas páginas)
        const maxVisible = 5;
        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, startPage + maxVisible - 1);

        if (endPage - startPage < maxVisible - 1) {
            startPage = Math.max(1, endPage - maxVisible + 1);
        }

        if (startPage > 1) {
            buttonsHtml += `
                <button onclick="loadAlunos(1)" class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded hover:bg-surface-container-low font-label-bold text-label-bold">1</button>
            `;
            if (startPage > 2) {
                buttonsHtml += `<span class="px-sm text-on-surface-variant">...</span>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            const activeClass = i === currentPage 
                ? 'bg-primary text-on-primary font-label-bold text-label-bold rounded' 
                : 'border border-outline-variant rounded hover:bg-surface-container-low font-label-bold text-label-bold';
            buttonsHtml += `
                <button onclick="loadAlunos(\${i})" class="w-8 h-8 flex items-center justify-center \${activeClass}">\${i}</button>
            `;
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                buttonsHtml += `<span class="px-sm text-on-surface-variant">...</span>`;
            }
            buttonsHtml += `
                <button onclick="loadAlunos(\${totalPages})" class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded hover:bg-surface-container-low font-label-bold text-label-bold">\${totalPages}</button>
            `;
        }

        // Botão Próximo (Chevron Right)
        const nextDisabled = currentPage === totalPages ? 'disabled' : '';
        buttonsHtml += `
            <button onclick="if(currentPage < \${totalPages}) loadAlunos(currentPage + 1)" 
                    class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded hover:bg-surface-container-low disabled:opacity-30" 
                    \${nextDisabled}>
                <span class="material-symbols-outlined text-body-md">chevron_right</span>
            </button>
        `;

        paginationButtons.innerHTML = buttonsHtml;
    }

    // Função de debounce para busca enquanto digita
    function onSearchInput() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            loadAlunos(1);
        }, 200); // 200ms de delay para evitar requisições excessivas
    }

    // Listeners
    filterNome.addEventListener('input', onSearchInput);
    filterMatricula.addEventListener('input', onSearchInput);

    // Carregamento inicial
    document.addEventListener('DOMContentLoaded', () => {
        loadAlunos(1);
    });
</script>
</body></html>