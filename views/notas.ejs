<!DOCTYPE html>

<html lang="pt-BR"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Hanken+Grotesk:wght@600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f3f5;
        }
        ::-webkit-scrollbar-thumb {
            background: #ced4da;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #adb5bd;
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-container": "#212425",
                        "inverse-surface": "#293138",
                        "on-error-container": "#93000a",
                        "surface-variant": "#dbe4ed",
                        "on-tertiary-fixed-variant": "#454748",
                        "on-tertiary-fixed": "#191c1d",
                        "surface-container-low": "#ecf5fe",
                        "on-background": "#141d23",
                        "on-secondary": "#ffffff",
                        "tertiary-fixed": "#e1e3e4",
                        "primary-fixed": "#d6e3ff",
                        "on-secondary-fixed": "#00210c",
                        "on-primary-fixed-variant": "#2c4771",
                        "on-tertiary": "#ffffff",
                        "primary-fixed-dim": "#adc7f8",
                        "surface-bright": "#f6faff",
                        "surface-container-highest": "#dbe4ed",
                        "inverse-primary": "#adc7f8",
                        "on-primary-fixed": "#001b3d",
                        "surface": "#f6faff",
                        "on-primary": "#ffffff",
                        "primary-container": "#00234b",
                        "background": "#f6faff",
                        "error": "#ba1a1a",
                        "error-container": "#ffdad6",
                        "surface-dim": "#d2dbe4",
                        "inverse-on-surface": "#e9f2fb",
                        "on-primary-container": "#718bb9",
                        "surface-tint": "#455f8a",
                        "on-secondary-container": "#00743a",
                        "surface-container-high": "#e0e9f2",
                        "tertiary": "#0c0e0f",
                        "surface-container-lowest": "#ffffff",
                        "surface-container": "#e6eff8",
                        "outline-variant": "#c4c6d0",
                        "on-tertiary-container": "#898b8c",
                        "primary": "#000e24",
                        "secondary-container": "#6bfe9c",
                        "on-surface": "#141d23",
                        "on-surface-variant": "#43474e",
                        "on-error": "#ffffff",
                        "tertiary-fixed-dim": "#c5c7c8",
                        "secondary": "#006d37",
                        "on-secondary-fixed-variant": "#005228",
                        "secondary-fixed-dim": "#4ae183",
                        "outline": "#74777f",
                        "secondary-fixed": "#6bfe9c"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "xs": "4px",
                        "sidebar_width": "260px",
                        "unit": "4px",
                        "gutter": "16px",
                        "lg": "24px",
                        "xl": "32px",
                        "sm": "8px",
                        "md": "16px",
                        "header_height": "64px"
                    },
                    "fontFamily": {
                        "headline-md": ["Hanken Grotesk"],
                        "label-bold": ["Inter"],
                        "body-sm": ["Inter"],
                        "body-md": ["Inter"],
                        "title-sm": ["Inter"],
                        "label-sm": ["Inter"],
                        "display-lg": ["Hanken Grotesk"]
                    },
                    "fontSize": {
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "label-bold": ["12px", {"lineHeight": "16px", "fontWeight": "600"}],
                        "body-sm": ["13px", {"lineHeight": "18px", "fontWeight": "400"}],
                        "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                        "title-sm": ["18px", {"lineHeight": "24px", "fontWeight": "600"}],
                        "label-sm": ["11px", {"lineHeight": "14px", "fontWeight": "500"}],
                        "display-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "700"}]
                    }
                },
            },
        }
    </script>
    <%- include('partials/sidebar_css') %>
</head>
<body class="bg-background text-on-background font-body-md">
<!-- SideNavBar -->
<%- include('partials/sidebar') %>
<!-- TopNavBar -->
<%- include('partials/top_header') %>
<!-- Main Content -->
<main class="pt-header_height pl-sidebar_width min-h-screen">
<div class="p-lg">
<!-- Breadcrumbs & Header -->
<div class="mb-lg">

<h3 class="font-display-lg text-display-lg text-primary">Lançamento de Notas</h3>
</div>
<!-- Dashboard Layout (Bento Grid Style) -->
<div class="grid grid-cols-12 gap-gutter">
<!-- Filters Section -->
<section class="col-span-12 bg-white p-lg rounded-xl border border-outline-variant shadow-sm">
<div class="flex flex-wrap items-end gap-lg">
<div class="flex-1 min-w-[240px]">
<label class="block font-label-bold text-on-surface-variant mb-xs">Selecione a Turma</label>
<div class="relative">
<select id="select-turma" class="w-full h-[40px] border border-outline rounded px-md appearance-none bg-surface-container-lowest focus:border-primary focus:ring-0">
<% if (locals.turmas && turmas.length > 0) { %>
    <% turmas.forEach(turma => { %>
        <option value="<%= turma.idTurma %>"><%= turma.turma_nome %> (<%= turma.turma_ano %>)</option>
    <% }); %>
<% } else { %>
    <option value="">Nenhuma turma encontrada</option>
<% } %>
</select>
</div>
</div>
<div class="flex-1 min-w-[240px]">
<label class="block font-label-bold text-on-surface-variant mb-xs">Selecione a Disciplina</label>
<div class="relative">
<select id="select-disciplina" class="w-full h-[40px] border border-outline rounded px-md appearance-none bg-surface-container-lowest focus:border-primary focus:ring-0">
<% if (locals.disciplinas && disciplinas.length > 0) { %>
    <% disciplinas.forEach(disciplina => { %>
        <option value="<%= disciplina.idDisc %>"><%= disciplina.disc_nome %></option>
    <% }); %>
<% } else { %>
    <option value="">Nenhuma disciplina encontrada</option>
<% } %>
</select>
</div>
</div>
<button id="btn-filtrar" class="bg-primary text-on-primary px-xl h-[40px] rounded font-label-bold flex items-center gap-sm hover:opacity-90 transition-opacity">
<span class="material-symbols-outlined" data-icon="filter_list">filter_list</span>
                            Filtrar
                        </button>
</div>
</section>
<!-- Data Table Section (Main Grid) -->
<section class="col-span-12 lg:col-span-8 bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden">
<div class="bg-surface-container px-lg py-md border-b border-outline-variant flex justify-between items-center">
<h4 class="font-title-sm text-primary">Lista de Alunos</h4>
<span id="total-alunos-contador" class="text-label-sm text-on-surface-variant">0 alunos encontrados</span>
</div>
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead class="bg-[#F1F3F5] sticky top-0">
<tr>
<th class="px-lg py-md font-label-bold text-on-surface-variant text-[12px] border-b border-outline-variant">MATRÍCULA</th>
<th class="px-lg py-md font-label-bold text-on-surface-variant text-[12px] border-b border-outline-variant">NOME DO ALUNO</th>
<th class="px-lg py-md font-label-bold text-on-surface-variant text-[12px] border-b border-outline-variant text-center">N1</th>
<th class="px-lg py-md font-label-bold text-on-surface-variant text-[12px] border-b border-outline-variant text-center">N2</th>
<th class="px-lg py-md font-label-bold text-on-surface-variant text-[12px] border-b border-outline-variant text-center">N3</th>
<th class="px-lg py-md font-label-bold text-on-surface-variant text-[12px] border-b border-outline-variant text-center">MÉDIA</th>
<th class="px-lg py-md font-label-bold text-on-surface-variant text-[12px] border-b border-outline-variant">STATUS</th>
</tr>
</thead>
<tbody id="tabela-notas-corpo" class="divide-y divide-outline-variant">
<tr id="empty-state-row">
<td colspan="7" class="px-lg py-xl text-center text-on-surface-variant bg-surface-container-lowest">
    Selecione a turma e disciplina e clique em <strong>Filtrar</strong> para exibir a listagem de notas.
</td>
</tr>
</tbody>
</table>
</div>
<div class="p-md bg-surface-container-low border-t border-outline-variant flex justify-between items-center">
<p class="text-label-sm text-on-surface-variant">Nenhum filtro aplicado</p>
<div class="text-label-sm text-on-surface-variant italic">Utilize os seletores acima</div>
</div>
</section>
<!-- Input Form Section (Side Panel) -->
<aside class="col-span-12 lg:col-span-4 flex flex-col gap-gutter">
<section class="bg-white p-lg rounded-xl border border-outline-variant shadow-sm">
<div class="flex items-center gap-md mb-lg">
<div class="w-12 h-12 bg-primary-container rounded-lg flex items-center justify-center text-on-primary-container">
<span class="material-symbols-outlined text-[28px]" data-icon="edit_note">edit_note</span>
</div>
<div>
<h4 class="font-title-sm text-primary">Lançamento</h4>
<p id="nome-aluno-lancamento" class="text-label-sm text-on-surface-variant italic">Nenhum aluno selecionado</p>
</div>
</div>
<form id="form-lancamento" class="space-y-lg opacity-50 pointer-events-none transition-opacity duration-300">
<div>
<label class="block font-label-bold text-on-surface-variant mb-xs">Nota 1 (N1)</label>
<input id="input-nota1" class="w-full h-[40px] border border-outline rounded px-md focus:border-primary focus:ring-0 text-body-md" placeholder="0.0" min="0" max="10" step="0.1" type="number" disabled/>
</div>
<div>
<label class="block font-label-bold text-on-surface-variant mb-xs">Nota 2 (N2)</label>
<input id="input-nota2" class="w-full h-[40px] border border-outline rounded px-md focus:border-primary focus:ring-0 text-body-md" placeholder="0.0" min="0" max="10" step="0.1" type="number" disabled/>
</div>
<div>
<label class="block font-label-bold text-on-surface-variant mb-xs">Nota 3 (N3)</label>
<input id="input-nota3" class="w-full h-[40px] border border-outline rounded px-md focus:border-primary focus:ring-0 text-body-md" placeholder="0.0" min="0" max="10" step="0.1" type="number" disabled/>
</div>
<div class="pt-md bg-surface-container-lowest p-md rounded-lg border border-outline-variant">
<div class="flex justify-between items-center mb-xs">
<span class="text-label-sm text-on-surface-variant">Média Parcial:</span>
<span id="media-parcial-valor" class="font-headline-md text-primary">--</span>
</div>
<div class="w-full bg-surface-container h-2 rounded-full overflow-hidden">
<div id="media-parcial-barra" class="bg-secondary h-full transition-all duration-300" style="width: 0%;"></div>
</div>
</div>
<div class="flex flex-col gap-sm pt-md">
<button id="btn-salvar-notas" class="bg-secondary text-on-secondary w-full py-md rounded-lg font-label-bold flex items-center justify-center gap-sm shadow-lg shadow-secondary/10 hover:brightness-110 transition-all cursor-not-allowed opacity-80" type="button" disabled>
<span class="material-symbols-outlined" data-icon="save">save</span>
                                    Salvar Notas
                                </button>
<button id="btn-limpar-notas" class="border border-outline text-on-surface-variant w-full py-md rounded-lg font-label-bold hover:bg-surface-container-low transition-colors" type="button">
                                    Limpar Campos
                                </button>
</div>
</form>
</section>
<!-- Info Alert -->
<div class="bg-surface-container-low p-md rounded-xl border border-outline-variant flex gap-md">
<span class="material-symbols-outlined text-primary-container" data-icon="info">info</span>
<div>
<p class="font-label-bold text-primary">Importante</p>
<p class="text-body-sm text-on-surface-variant mt-xs">As notas lançadas serão enviadas automaticamente para o portal do aluno após a confirmação do coordenador.</p>
</div>
</div>
</aside>
</div>
</div>
</main>
<!-- Contextual FAB (Hidden as per relevance check, but keeping structure for shell consistency if needed) -->
<!-- FAB is suppressed here because the primary action is embedded in the main dashboard/form flow -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const selectTurma = document.getElementById('select-turma');
    const selectDisciplina = document.getElementById('select-disciplina');
    const btnFiltrar = document.getElementById('btn-filtrar');
    const tabelaCorpo = document.getElementById('tabela-notas-corpo');
    const totalContador = document.getElementById('total-alunos-contador');
    const paginacaoDiv = document.querySelector('.p-md.bg-surface-container-low.border-t');

    // Elementos do painel lateral
    const formLancamento = document.getElementById('form-lancamento');
    const nomeAlunoLancamento = document.getElementById('nome-aluno-lancamento');
    const inputNota1 = document.getElementById('input-nota1');
    const inputNota2 = document.getElementById('input-nota2');
    const inputNota3 = document.getElementById('input-nota3');
    const mediaValor = document.getElementById('media-parcial-valor');
    const mediaBarra = document.getElementById('media-parcial-barra');
    const btnSalvar = document.getElementById('btn-salvar-notas');
    const btnLimpar = document.getElementById('btn-limpar-notas');

    let alunosDados = [];
    let alunoSelecionado = null;

    // Função para atualizar a média calculada no formulário lateral
    function recalcularMediaForm() {
        const n1 = parseFloat(inputNota1.value);
        const n2 = parseFloat(inputNota2.value);
        const n3 = parseFloat(inputNota3.value);

        // Se pelo menos uma nota estiver preenchida, calculamos a média das notas preenchidas
        let preenchidas = 0;
        let soma = 0;
        if (!isNaN(n1)) { soma += n1; preenchidas++; }
        if (!isNaN(n2)) { soma += n2; preenchidas++; }
        if (!isNaN(n3)) { soma += n3; preenchidas++; }

        if (preenchidas > 0) {
            const media = (soma / 3.0).toFixed(1);
            mediaValor.textContent = media;
            mediaBarra.style.width = `${media * 10}%`;
            
            // Muda cor da média com base no valor
            if (media >= 7.0) {
                mediaValor.className = 'font-headline-md text-secondary';
                mediaBarra.className = 'bg-secondary h-full transition-all duration-300';
            } else if (preenchidas === 3) {
                mediaValor.className = 'font-headline-md text-error';
                mediaBarra.className = 'bg-error h-full transition-all duration-300';
            } else {
                mediaValor.className = 'font-headline-md text-primary';
                mediaBarra.className = 'bg-primary-container h-full transition-all duration-300';
            }
        } else {
            mediaValor.textContent = '--';
            mediaBarra.style.width = '0%';
            mediaValor.className = 'font-headline-md text-primary';
        }
    }

    [inputNota1, inputNota2, inputNota3].forEach(input => {
        input.addEventListener('input', () => {
            // Limitar entre 0 e 10
            let val = parseFloat(input.value);
            if (val < 0) input.value = 0;
            if (val > 10) input.value = 10;
            recalcularMediaForm();
        });
    });

    // Função para selecionar um aluno da tabela
    window.selecionarAluno = (idAluno) => {
        const aluno = alunosDados.find(a => a.idAluno === idAluno);
        if (!aluno) return;

        alunoSelecionado = aluno;
        nomeAlunoLancamento.textContent = `${aluno.aluno_nome} (${aluno.aluno_matricula})`;
        nomeAlunoLancamento.classList.remove('italic');

        // Preenche notas
        inputNota1.value = aluno.avali_nota1 !== null ? aluno.avali_nota1 : '';
        inputNota2.value = aluno.avali_nota2 !== null ? aluno.avali_nota2 : '';
        inputNota3.value = aluno.avali_nota3 !== null ? aluno.avali_nota3 : '';

        // Habilita formulário
        formLancamento.classList.remove('opacity-50', 'pointer-events-none');
        [inputNota1, inputNota2, inputNota3, btnSalvar].forEach(el => {
            el.removeAttribute('disabled');
        });
        btnSalvar.classList.remove('cursor-not-allowed', 'opacity-80');

        recalcularMediaForm();

        // Remove classe ativa de todas as linhas e adiciona na selecionada
        document.querySelectorAll('#tabela-notas-corpo tr').forEach(row => {
            row.classList.remove('bg-blue-50/50', 'border-l-4', 'border-primary');
        });
        const activeRow = document.getElementById(`aluno-row-${idAluno}`);
        if (activeRow) {
            activeRow.classList.add('bg-blue-50/50', 'border-l-4', 'border-primary');
        }
    };

    // Botão Limpar
    btnLimpar.addEventListener('click', () => {
        inputNota1.value = '';
        inputNota2.value = '';
        inputNota3.value = '';
        recalcularMediaForm();
    });

    // Botão Salvar
    btnSalvar.addEventListener('click', async () => {
        if (!alunoSelecionado) return;

        const idTurma = selectTurma.value;
        const idDisc = selectDisciplina.value;

        // Feedback de salvamento
        btnSalvar.setAttribute('disabled', 'true');
        btnSalvar.innerHTML = `<span class="material-symbols-outlined animate-spin" data-icon="sync">sync</span> Salvando...`;

        try {
            const response = await fetch('/api/notas/salvar', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    idAluno: alunoSelecionado.idAluno,
                    idTurma: idTurma,
                    idDisc: idDisc,
                    nota1: inputNota1.value,
                    nota2: inputNota2.value,
                    nota3: inputNota3.value
                })
            });

            const data = await response.json();
            if (data.success) {
                // Atualizar dados na lista e recarregar filtro
                await filtrarNotas(false); // recarrega a tabela mantendo seleção do aluno
                
                // Mostrar banner de sucesso temporário
                const banner = document.createElement('div');
                banner.className = 'fixed bottom-4 right-4 bg-green-500 text-white px-md py-sm rounded shadow-lg z-50 flex items-center gap-sm transition-all duration-300';
                banner.innerHTML = `<span class="material-symbols-outlined" data-icon="check_circle">check_circle</span> ` + data.message;
                document.body.appendChild(banner);
                setTimeout(() => {
                    banner.remove();
                }, 3000);
            } else {
                alert('Erro ao salvar: ' + data.error);
            }
        } catch (err) {
            console.error('Erro de rede ao salvar notas:', err);
            alert('Erro de rede ao tentar salvar as notas.');
        } finally {
            btnSalvar.removeAttribute('disabled');
            btnSalvar.innerHTML = `<span class="material-symbols-outlined" data-icon="save">save</span> Salvar Notas`;
        }
    });

    // Função de Filtrar Notas
    async function filtrarNotas(resetSelection = true) {
        const idTurma = selectTurma.value;
        const idDisc = selectDisciplina.value;

        if (!idTurma || !idDisc) return;

        // Mostrar loading na tabela
        tabelaCorpo.innerHTML = `
            <tr>
                <td colspan="7" class="px-lg py-xl text-center text-on-surface-variant bg-surface-container-lowest">
                    <span class="material-symbols-outlined animate-spin text-[32px] text-primary" data-icon="sync">sync</span>
                    <p class="mt-xs font-label-bold">Buscando alunos e notas...</p>
                </td>
            </tr>
        `;

        try {
            const response = await fetch(`/api/notas?idTurma=${idTurma}&idDisc=${idDisc}`);
            const data = await response.json();

            if (data.sucesso) {
                alunosDados = data.alunos;
                totalContador.textContent = `${alunosDados.length} alunos encontrados`;

                // Atualizar texto do painel de paginação
                if (paginacaoDiv) {
                    paginacaoDiv.innerHTML = `
                        <p class="text-label-sm text-on-surface-variant">Exibindo todos os ${alunosDados.length} alunos da turma</p>
                        <div class="text-label-sm text-on-surface-variant italic">Selecione um aluno para lançar notas</div>
                    `;
                }

                if (alunosDados.length === 0) {
                    tabelaCorpo.innerHTML = `
                        <tr>
                            <td colspan="7" class="px-lg py-xl text-center text-on-surface-variant bg-surface-container-lowest">
                                Nenhum aluno cadastrado nesta turma.
                            </td>
                        </tr>
                    `;
                    // Resetar form
                    resetForm();
                    return;
                }

                tabelaCorpo.innerHTML = '';
                alunosDados.forEach(aluno => {
                    const row = document.createElement('tr');
                    row.id = `aluno-row-${aluno.idAluno}`;
                    row.className = 'hover:bg-surface-container-low transition-colors cursor-pointer border-b border-outline-variant';
                    row.setAttribute('onclick', `selecionarAluno(${aluno.idAluno})`);

                    const n1 = aluno.avali_nota1 !== null ? aluno.avali_nota1.toFixed(1) : '--';
                    const n2 = aluno.avali_nota2 !== null ? aluno.avali_nota2.toFixed(1) : '--';
                    const n3 = aluno.avali_nota3 !== null ? aluno.avali_nota3.toFixed(1) : '--';
                    
                    let media = '--';
                    let statusLabel = 'Pendente';
                    let badgeClass = 'bg-blue-100 text-primary';
                    let mediaClass = 'text-on-surface-variant';

                    if (aluno.avali_nota1 !== null && aluno.avali_nota2 !== null && aluno.avali_nota3 !== null) {
                        media = aluno.avali_media !== null ? aluno.avali_media.toFixed(1) : ((aluno.avali_nota1 + aluno.avali_nota2 + aluno.avali_nota3) / 3.0).toFixed(1);
                        const mediaNum = parseFloat(media);
                        if (mediaNum >= 7.0) {
                            statusLabel = 'Aprovado';
                            badgeClass = 'bg-green-100 text-secondary';
                            mediaClass = 'font-bold text-secondary';
                        } else {
                            statusLabel = 'Reprovado';
                            badgeClass = 'bg-red-100 text-error';
                            mediaClass = 'font-bold text-error';
                        }
                    } else if (aluno.avali_nota1 !== null || aluno.avali_nota2 !== null || aluno.avali_nota3 !== null) {
                        // Média parcial
                        let soma = 0;
                        let cont = 0;
                        if (aluno.avali_nota1 !== null) { soma += aluno.avali_nota1; cont++; }
                        if (aluno.avali_nota2 !== null) { soma += aluno.avali_nota2; cont++; }
                        if (aluno.avali_nota3 !== null) { soma += aluno.avali_nota3; cont++; }
                        media = (soma / 3.0).toFixed(1);
                        mediaClass = 'font-semibold text-primary';
                    }

                    row.innerHTML = `
                        <td class="px-lg py-md font-label-bold text-primary">${aluno.aluno_matricula}</td>
                        <td class="px-lg py-md text-on-surface">${aluno.aluno_nome}</td>
                        <td class="px-lg py-md text-center text-on-surface-variant">${n1}</td>
                        <td class="px-lg py-md text-center text-on-surface-variant">${n2}</td>
                        <td class="px-lg py-md text-center text-on-surface-variant">${n3}</td>
                        <td class="px-lg py-md text-center ${mediaClass}">${media}</td>
                        <td class="px-lg py-md">
                            <span class="px-sm py-xs rounded-full ${badgeClass} text-[11px] font-bold uppercase tracking-wider">${statusLabel}</span>
                        </td>
                    `;
                    tabelaCorpo.appendChild(row);
                });

                if (resetSelection) {
                    resetForm();
                } else if (alunoSelecionado) {
                    // Mantém o aluno selecionado ativo visualmente
                    selecionarAluno(alunoSelecionado.idAluno);
                }

            } else {
                tabelaCorpo.innerHTML = `
                    <tr>
                        <td colspan="7" class="px-lg py-xl text-center text-error bg-error-container/20">
                            Erro ao carregar dados do servidor.
                        </td>
                    </tr>
                `;
            }
        } catch (err) {
            console.error('Erro de rede ao buscar notas:', err);
            tabelaCorpo.innerHTML = `
                <tr>
                    <td colspan="7" class="px-lg py-xl text-center text-error bg-error-container/20">
                        Erro de conexão ao carregar dados.
                    </td>
                </tr>
            `;
        }
    }

    function resetForm() {
        alunoSelecionado = null;
        nomeAlunoLancamento.textContent = 'Nenhum aluno selecionado';
        nomeAlunoLancamento.classList.add('italic');
        inputNota1.value = '';
        inputNota2.value = '';
        inputNota3.value = '';
        mediaValor.textContent = '--';
        mediaBarra.style.width = '0%';
        mediaValor.className = 'font-headline-md text-primary';
        formLancamento.classList.add('opacity-50', 'pointer-events-none');
        [inputNota1, inputNota2, inputNota3, btnSalvar].forEach(el => {
            el.setAttribute('disabled', 'true');
        });
        btnSalvar.classList.add('cursor-not-allowed', 'opacity-80');
    }

    // Filtrar automaticamente no clique
    btnFiltrar.addEventListener('click', () => filtrarNotas(true));
});
</script>
</body></html>